{
  "name": "__MSG_extName__",
  "description": "__MSG_extDescription__",
  "default_locale": "en",
  "version": "0.6.1",
  "manifest_version": 3,
  "permissions": ["storage", "tabs", "alarms", "notifications", "identity"],
  "host_permissions": [
    "https://*.edupage.org/*",
    "https://edublurtesting.ct.ws/*",
    "https://raw.githubusercontent.com/Alexosavrua/Edupage-Extras/*",
    "https://accounts.google.com/*",
    "https://oauth2.googleapis.com/*",
    "https://www.googleapis.com/*"
  ],
  "background": {
    "service_worker": "scripts/background.js"
  },
  "commands": {
    "toggle-stay-active-mode": {
      "description": "Toggle Stay Active Mode"
    },
    "toggle-theme-mode": {
      "description": "Toggle Themes"
    }
  },
  "action": {
    "default_popup": "menu/menu.html",
    "default_icon": "images/placeholder_icon.png"
  },
  "options_ui": {
    "page": "menu/settings.html",
    "open_in_tab": true
  },
  "content_scripts": [
    {
      "matches": ["https://*.edupage.org/*"],
      "css": ["scripts/instant-theme.css"],
      "js": [
        "scripts/activity-shield-bridge.js",
        "scripts/content.js",
        "scripts/timetable-sync.js",
        "scripts/timetable-enhancer.js",
        "scripts/grades-enhancer.js",
        "scripts/attendance-enhancer.js"
      ],
      "run_at": "document_start",
      "all_frames": true,
      "match_about_blank": true
    },
    {
      "matches": [
        "https://*.edupage.org/*",
        "https://edublurtesting.ct.ws/*"
      ],
      "js": ["scripts/activity-shield-main.js"],
      "run_at": "document_start",
      "all_frames": true,
      "match_about_blank": true,
      "world": "MAIN"
    },
    {
      "matches": ["https://edublurtesting.ct.ws/*"],
      "js": ["scripts/activity-shield-bridge.js"],
      "run_at": "document_start",
      "all_frames": true,
      "match_about_blank": true
    }
  ]
}
